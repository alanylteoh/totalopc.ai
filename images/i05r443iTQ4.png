            <svg class="lang-chevron" viewBox="0 0 10 6" width="9" height="6" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" fill="none" stroke-width="1.4"/></svg>
          </button>
          <div class="lang-menu" role="menu">
        <a href="https://www.coze.cn/s/oZ-BqyQ1-R8/" role="menuitem" class="lang-option"><span class="lang-option-code">CN</span><span class="lang-option-name">简体中文</span></a>
        <a href="https://www.coze.cn/s/gwHDprSkMek/" role="menuitem" class="lang-option"><span class="lang-option-code">UK</span><span class="lang-option-name">English</span></a>
        <a href="https://www.coze.cn/s/lcTUJj8wY5w/" role="menuitem" class="lang-option"><span class="lang-option-code">MY</span><span class="lang-option-name">Bahasa Melayu</span></a>
        <a href="https://www.coze.cn/s/iJg6TYY0YGs/" role="menuitem" class="lang-option"><span class="lang-option-code">HK</span><span class="lang-option-name">繁體中文</span></a>
        <a href="https://www.coze.cn/s/ilJ6BFP-yPY/" role="menuitem" class="lang-option"><span class="lang-option-code">TH</span><span class="lang-option-name">ภาษาไทย</span></a>
        <a href="https://www.coze.cn/s/iqK89VRLl-k/" role="menuitem" class="lang-option"><span class="lang-option-code">ID</span><span class="lang-option-name">Bahasa Indonesia</span></a>
        <a href="https://www.coze.cn/s/i05r443iTQ4/" role="menuitem" class="lang-option"><span class="lang-option-code">JP</span><span class="lang-option-name">日本語</span></a>
        <a href="https://www.coze.cn/s/oZIRjfuxiP0/" role="menuitem" class="lang-option"><span class="lang-option-code">KR</span><span class="lang-option-name">한국어</span></a>
          </div>
        </div>
