<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TOTAL OPC SDN. BHD. — OPC 孵化プラットフォーム | OPC + AI研修 · 企業診断 · 資本運営</title>
  <meta name="description" content="マレーシアベースのOPC孵化プラットフォーム。三つの顧問任務：OPC + AI研修、企業診断、資本運営。独立創業者向けサービス。">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;600;700;900&family=Noto+Sans+JP:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700;800;900&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,500;1,9..144,600;1,9..144,700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800;1,900&family=DM+Serif+Display&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      /* === 革命：去沉加希望（暖白主调 + 深蓝点缀）=== */
      --ink:#0a1628;        /* 深蓝黑 — 主要文字 / 深色段底（仅 Hero/Global 用） */
      --blue-deep:#122849;  /* 深蓝（Global 段用，比 ink 更蓝） */
      --paper:#f5f0e1;      /* 米色温暖背景（替代 --paper #0d1929） */
      --white:#fff;--off:#faf6ed;--sand:#f3ebd9;
      --g100:#faf6ed;--g200:#ece6d4;--g300:#d6cdb6;--g400:#8a8473;--g500:#5e5848;--g600:#3a3528;--g700:#1f1c14;
      --blue:#1e3a5f;       /* 链接/数据/规则（保留） */
      --purple:#5b4fc4;     /* 紫色 accent（Pentagram Editorial 用） */
      --gold:#c9a04a;       /* 高亮/几何符号（保留） */
      --orange:#ff6b35;     /* 活力/CTA（保留） */
      --rule:#2a3142;       /* 深色段边框 */
      --rule-light:rgba(201,160,74,.25); /* 浅色段金色透明边框 */
      /* === 字体系统：英文 didone + 中文宋体，视觉和谐 === */
      --serif:'Noto Serif JP','Hiragino Mincho ProN','Yu Mincho',Georgia,'Times New Roman',serif;
      --serif-en:'Playfair Display','DM Serif Display','Fraunces',Georgia,'Noto Serif JP',serif;
      --sans:'Inter','Noto Sans JP',-apple-system,BlinkMacSystemFont,'Helvetica Neue','Hiragino Kaku Gothic ProN',sans-serif;
      --sans-jp:'Noto Sans JP','Hiragino Kaku Gothic ProN',-apple-system,sans-serif;
      --display:'Fraunces','Playfair Display','Noto Serif JP',Georgia,serif;
      --display-jp:'Noto Serif JP','Hiragino Mincho ProN',Georgia,serif;
      --mono:'JetBrains Mono','IBM Plex Mono','Courier New',monospace;
    }
    html{font-size:16px;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;scroll-behavior:smooth}
    body{font-family:var(--sans);color:var(--ink);background:var(--off);line-height:1.78;overflow-x:hidden;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;text-rendering:optimizeLegibility;font-feature-settings:'kern' 1,'liga' 1,'calt' 1,'ss01' 1;letter-spacing:.01em}
    a{text-decoration:none;color:inherit}
    img{max-width:100%;height:auto;display:block}
    ::selection{background:var(--blue);color:#fff}

    /* ── NAV ── */
    .nav{position:fixed;top:0;left:0;right:0;z-index:200;height:88px;transition:all .4s}
    .nav.scrolled{background:rgba(250,246,237,.95);backdrop-filter:blur(20px);border-bottom:1px solid rgba(30,58,95,.12);box-shadow:0 4px 24px -8px rgba(10,22,40,.08)}
    .nav-in{max-width:1440px;margin:0 auto;padding:0 48px;display:flex;align-items:center;justify-content:space-between;height:100%}
    .nav-logo{display:flex;align-items:center;gap:12px}
    .nav-logo img{height:65px}
    .nav-brand{font-family:var(--serif);font-weight:700;font-size:22px;letter-spacing:.5px;color:#fff;transition:color .4s}
    .nav.scrolled .nav-brand{color:var(--ink)}
    .nav-right{display:flex;align-items:center;gap:40px}
    .nav-link{font-size:14px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.75);transition:color .3s;position:relative;font-family:var(--mono)}
    .nav.scrolled .nav-link{color:rgba(30,58,95,.7)}
    .nav-link:hover{color:#fff}
    .nav.scrolled .nav-link:hover{color:var(--orange)}
    .nav-lang{font-size:14px;font-weight:700;letter-spacing:2px;color:rgba(201,160,74,.85);transition:color .3s}
    .nav.scrolled .nav-lang{color:rgba(201,160,74,.7)}
    .nav-lang:hover{color:#fff}
    .nav.scrolled .nav-lang:hover{color:var(--orange)}
    .nav-cta{padding:10px 22px;border:1px solid rgba(255,255,255,.5);font-size:14px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:#fff;transition:all .3s;font-family:var(--mono)}
    .nav.scrolled .nav-cta{border-color:var(--blue);color:var(--blue)}
    .nav-cta:hover{background:#fff;color:var(--ink)}
    .nav.scrolled .nav-cta:hover{background:var(--blue);color:#fff}
    /* ── LANG SWITCHER (v8.1 dropdown) ── */
    .lang-switcher{position:relative;display:inline-block}
    .lang-btn{display:inline-flex;align-items:center;gap:8px;background:transparent;border:1px solid rgba(201,160,74,.5);padding:9px 14px;font-family:var(--mono);font-size:13px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:rgba(201,160,74,.9);cursor:pointer;transition:all .3s;line-height:1}
    .nav.scrolled .lang-btn{color:rgba(30,58,95,.85);border-color:rgba(30,58,95,.3)}
    .lang-btn:hover{color:#fff;border-color:rgba(201,160,74,.85)}
    .nav.scrolled .lang-btn:hover{color:var(--blue);border-color:var(--blue)}
    .lang-chevron{transition:transform .3s cubic-bezier(.4,0,.2,1);opacity:.7}
    .lang-switcher.open .lang-chevron{transform:rotate(180deg);opacity:1}
    .lang-menu{position:absolute;top:calc(100% + 10px);right:0;min-width:180px;background:#fff;border:1px solid var(--ink);opacity:0;visibility:hidden;transform:translateY(-6px);transition:opacity .25s,transform .25s,visibility .25s;z-index:300;padding:6px 0}
    .lang-switcher.open .lang-menu{opacity:1;visibility:visible;transform:translateY(0)}
    .lang-option{display:flex;align-items:center;justify-content:space-between;padding:11px 16px;font-family:var(--mono);font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--ink);transition:background .2s,color .2s;border-bottom:1px solid rgba(30,58,95,.08);line-height:1}
    .lang-option:last-child{border-bottom:none}
    .lang-option:hover{background:rgba(91,79,196,.06);color:var(--purple)}
    .lang-option-code{font-weight:700;color:var(--ink);transition:color .2s}
    .lang-option:hover .lang-option-code{color:var(--purple)}
    .lang-option-name{font-size:10px;font-weight:500;letter-spacing:1px;color:var(--g500);text-transform:none;font-family:var(--sans)}

    @media(max-width:1024px){.nav-link{display:none}.lang-switcher{display:inline-block}.nav-cta{display:none}}
    @media(max-width:640px){.nav-in{padding:0 20px}.nav-brand{font-size:19px;letter-spacing:0}.nav-logo img{height:52px}}

    /* ── HERO ── */
    .hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;overflow:hidden}
    .hero-bg{position:absolute;inset:0;z-index:0}
    .hero-bg img{width:100%;height:100%;object-fit:cover;object-position:center 35%}
    .hero-geom{position:absolute;z-index:2;pointer-events:none}
    .hero-geom-circle{top:18%;left:8%;width:80px;height:80px;border:1px solid rgba(201,160,74,.5);border-radius:50%}
    .hero-geom-tri{bottom:25%;right:12%;width:0;height:0;border-left:24px solid transparent;border-right:24px solid transparent;border-bottom:42px solid rgba(201,160,74,.35)}
    .hero-geom-line{top:42%;right:18%;width:80px;height:1px;background:rgba(201,160,74,.6)}
    .hero-geom-square{top:62%;left:14%;width:8px;height:8px;background:var(--orange);transform:rotate(45deg);opacity:.5}
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(170deg,rgba(10,22,40,.22) 0%,rgba(10,22,40,.10) 50%,rgba(10,22,40,.42) 100%);z-index:1}
    .hero-overlay-warm{position:absolute;inset:0;background:linear-gradient(170deg,rgba(255,107,53,.18) 0%,rgba(201,160,74,.22) 50%,rgba(201,160,74,.18) 100%);mix-blend-mode:screen;z-index:1;pointer-events:none}
    .hero-inner{position:relative;z-index:2;max-width:1440px;margin:0 auto;padding:0 48px 100px;width:100%;padding-top:200px}
    .hero-kicker{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:5px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:32px}
    .hero h1{font-family:var(--serif-en);font-size:clamp(40px,6vw,88px);font-weight:700;line-height:1.08;letter-spacing:-0.5px;color:#fff;max-width:1200px;margin-bottom:32px}
    .hero h1 em{font-family:var(--display-jp);font-style:normal;color:var(--gold);font-weight:600;font-size:.58em;letter-spacing:.3px;line-height:1;display:inline-block;padding:0 .05em}
    .hero-body{max-width:600px;margin-bottom:48px}
    .hero-body p{font-size:16px;line-height:1.85;color:rgba(255,255,255,.78);margin-bottom:12px;letter-spacing:.1px}
    .hero-body p:last-child{font-size:13px;color:rgba(255,255,255,.45);font-style:normal;font-family:var(--display-jp);font-weight:500;margin-top:18px;letter-spacing:.5px;padding-left:14px;border-left:1px solid rgba(201,160,74,.4)}
    .hero-ctas{display:flex;gap:16px;flex-wrap:wrap}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:16px 32px;font-size:13px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;cursor:pointer;border:none;transition:all .35s cubic-bezier(.4,0,.2,1);font-family:var(--mono);white-space:nowrap}
    .btn-fill{background:#fff;color:var(--ink)}
    .btn-fill:hover{background:var(--blue);color:#fff}
    .btn-ghost{background:transparent;color:rgba(255,255,255,.8);border:1px solid rgba(255,255,255,.25)}
    .btn-ghost:hover{border-color:rgba(255,255,255,.7);color:#fff}

    .hero-stats-bar{position:relative;z-index:2;max-width:1440px;margin:0 auto;padding:0 48px}
    .hero-stats{display:flex;gap:0;border-top:1px solid rgba(255,255,255,.12);border-bottom:1px solid rgba(255,255,255,.12)}
    .hero-stat{flex:1;padding:56px 40px;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative}
    .hero-stat:not(:last-child)::after{content:'';position:absolute;top:18%;bottom:18%;right:0;width:1px;background:rgba(255,255,255,.14)}
    .hero-stat-num{font-size:clamp(24px,3vw,32px);font-weight:700;color:#fff;line-height:1.05;font-family:var(--sans);text-align:center;letter-spacing:-.3px;display:flex;align-items:baseline;justify-content:center;gap:8px;flex-wrap:nowrap;width:100%}
    .hero-stat-num .u{font-size:14px;font-weight:500;color:rgba(255,255,255,.55);margin-left:2px}
    .hero-stat-num .p{color:var(--gold);letter-spacing:.5px}
    .hero-stat-num .g{color:#c9a84c}
    .hero-stat-num .plus{color:var(--gold);font-weight:600;opacity:.7;font-size:.85em}
    .hero-stat-lbl{font-size:11px;font-weight:700;letter-spacing:4.5px;text-transform:uppercase;color:rgba(255,255,255,.6);margin-top:24px;text-align:center;white-space:nowrap;width:100%}

    @media(max-width:1024px){
      .hero-inner{padding:0 32px 80px;padding-top:160px}
      .hero-stats-bar{padding:0 32px}
      .hero-ctas{gap:12px}
    }
    @media(max-width:640px){
      .hero-inner{padding:0 20px 60px;padding-top:140px}
      .hero-stats-bar{padding:0 20px}
      .hero-stats{flex-wrap:wrap;gap:0}
      .hero-stat{flex:1 1 50%;border-bottom:1px solid rgba(255,255,255,.06);padding:32px 16px}
      .hero-stat:nth-child(odd)::after{display:none}
      .hero-stat:nth-child(even)::after{top:15%;bottom:15%;background:rgba(255,255,255,.1)}
      .hero-stat:nth-last-child(-n+2){border-bottom:none}
      .hero-stat-num{font-size:24px;gap:6px;flex-wrap:nowrap}
      .hero-stat-lbl{font-size:10px;letter-spacing:3px;margin-top:16px}
      .hero-ctas{flex-direction:column;width:100%}
      .hero-ctas .btn{width:100%;justify-content:center}
      .hero-geom-circle{width:60px;height:60px;top:14%;left:4%}
      .hero-geom-tri{bottom:18%;right:6%;border-left-width:18px;border-right-width:18px;border-bottom-width:32px}
      .hero-geom-line{width:60px;top:38%;right:8%}
    }

    /* ── SECTION UTIL ── */
    
    /* ════════════════════════════════════════
       v6.0 HERO MANIFESTO — 极简全屏铭文
       调性：Apple / Vitra / Dieter Rams
       抛弃：kicker / h1 / body / ctas / stats
       保留：bg / overlay / 极简几何
       ════════════════════════════════════════ */
    .hero-v6 .hero-bg{position:absolute;inset:0;z-index:0;overflow:hidden}
    .hero-v6 .hero-bg img{width:100%;height:100%;object-fit:cover;object-position:center 35%;filter:saturate(1.25) contrast(1.02) brightness(1.03);transform:scale(1.02)}
    .hero-v6 .hero-overlay{position:absolute;inset:0;background:linear-gradient(170deg,rgba(10,22,40,.30) 0%,rgba(10,22,40,.18) 45%,rgba(10,22,40,.48) 100%);z-index:1}
    .hero-v6 .hero-overlay-warm{position:absolute;inset:0;background:linear-gradient(180deg,rgba(201,160,74,.10) 0%,transparent 50%,rgba(10,22,40,.55) 100%);z-index:2}
    .hero-v6 .hero-geom{position:absolute;z-index:3;opacity:.35}
    .hero-v6 .hero-geom-tri{bottom:14%;right:5%;border-left:14px solid transparent;border-right:14px solid transparent;border-bottom:24px solid rgba(201,160,74,.5)}
    .hero-v6 .hero-geom-line{width:48px;height:1px;bottom:14%;right:14%;background:rgba(201,160,74,.5)}
    .hero-v6-content{position:relative;z-index:4;height:100vh;min-height:680px;max-width:1440px;margin:0 auto;padding:0 48px;display:flex;flex-direction:column;justify-content:flex-end;padding-bottom:96px;color:#fff}
    .hero-v6-kicker{font-family:var(--mono);font-size:13px;font-weight:500;letter-spacing:3.5px;text-transform:uppercase;color:rgba(201,160,74,.85);margin-bottom:32px;display:flex;align-items:center;gap:14px}
    .hero-v6-kicker::before{content:'';width:32px;height:1px;background:rgba(201,160,74,.7)}
    .hero-v6-title{font-family:var(--display-jp);font-weight:900;line-height:1.05;letter-spacing:-1px;margin:0 0 24px 0}
    .hero-v6-line{display:block;font-size:clamp(24px,4vw,56px);font-weight:700;line-height:1.2;letter-spacing:-.3px}
    .hero-v6-line:nth-child(2){font-family:var(--display-jp);font-weight:800}
    .hero-v6-line-em{font-family:var(--display);font-style:italic;font-weight:400;color:rgba(201,160,74,.95);font-size:clamp(36px,5.2vw,72px);letter-spacing:-1px;margin-top:-6px}
    .hero-v6-sub{font-family:var(--mono);font-style:normal;font-size:clamp(12px,1.1vw,15px);font-weight:600;letter-spacing:4px;text-transform:uppercase;color:rgba(201,160,74,.85);margin-bottom:64px;line-height:1.5}
    .hero-v6-foot{display:flex;align-items:center;gap:16px;font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.5)}
    .hero-v6-line-mark{width:32px;height:1px;background:rgba(255,255,255,.4)}
    .hero-v6-arrow{font-size:14px;animation:bob 2.2s ease-in-out infinite}
    @keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(4px)}}
    @media(max-width:1024px){.hero-v6-content{padding:0 32px;padding-bottom:80px}.hero-v6-line{font-size:clamp(22px,4.5vw,56px);line-height:1.22}}
    @media(max-width:640px){.hero-v6-content{padding:0 20px;padding-bottom:64px;justify-content:center}.hero-v6-kicker{font-size:14px;letter-spacing:3px;margin-bottom:24px}.hero-v6-line{font-size:20px;line-height:1.35;letter-spacing:0}.hero-v6-sub{font-size:12px;letter-spacing:3px;margin-bottom:56px}.hero-v6-foot{font-size:10px;letter-spacing:2px}.hero-v6-geom-tri,.hero-v6-geom-line{display:none}}

    /* ════════════════════════════════════════
       v6.0 ABOUT MANIFESTO — 黑底大字宣言
       抛弃：about-layout / about-card / about-pull / about-body
       新增：100vh / 黑底 / 居中大字铭文
       ════════════════════════════════════════ */
    .about-v7{position:relative;background:var(--off);color:var(--ink);padding:80px 0 100px;overflow:hidden;min-height:100vh;display:flex;flex-direction:column;justify-content:center}
    .about-v7-header{display:flex;align-items:center;gap:24px;max-width:1440px;margin:0 auto 80px;padding:0 48px}
    .about-v7-num{font-family:var(--mono);font-size:13px;font-weight:600;letter-spacing:2px;color:var(--purple);opacity:.85;font-variant-numeric:tabular-nums}
    .about-v7-label{font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:4px;text-transform:uppercase;color:var(--g400)}
    .about-v7-rule{flex:1;height:1px;background:linear-gradient(90deg,rgba(91,79,196,.4) 0%,rgba(201,160,74,.4) 50%,transparent 100%)}
    .about-v7-body{display:grid;grid-template-columns:7fr 5fr;gap:96px;max-width:1440px;margin:0 auto;padding:0 48px;align-items:start;position:relative;z-index:1}
    .about-v7-kicker{font-family:var(--mono);font-size:12px;font-weight:600;color:var(--purple);letter-spacing:5px;margin-bottom:40px;display:flex;align-items:center;gap:14px;text-transform:uppercase}
    .about-v7-kicker::before{content:'';width:48px;height:1px;background:var(--gold)}
    .about-v7-kicker-cn{font-family:var(--serif);font-weight:400;letter-spacing:8px;font-size:18px;margin-left:6px;color:var(--purple);text-transform:none}
    .about-v7-title{font-family:var(--serif-en);font-weight:700;line-height:1.08;letter-spacing:-0.5px;margin:0 0 24px 0;color:var(--ink);font-feature-settings:'kern' 1,'liga' 1}
    .about-v7-title .line-1{display:block;font-size:clamp(44px,6vw,88px);font-weight:700;color:var(--ink);letter-spacing:-0.5px}
    .about-v7-title .line-2{display:block;font-family:var(--display-jp);font-style:normal;font-weight:600;font-size:clamp(36px,5vw,72px);color:var(--purple);letter-spacing:-0.5px;margin-top:8px;line-height:1.05}
    .about-v7-title .line-2 em{font-family:var(--display);font-style:italic;font-weight:500;color:var(--gold);font-size:.45em;letter-spacing:0;margin-left:.15em;vertical-align:.18em;display:inline-block}
    .about-v7-info-col{display:flex;flex-direction:column;gap:48px;padding-top:0}
    .about-v7-manifesto{padding:0 0 0 24px;border-left:1px solid rgba(91,79,196,.25);position:relative}
    .about-v7-manifesto::before{content:'';position:absolute;left:-1px;top:0;width:1px;height:24px;background:var(--purple)}
    .about-v7-manifesto p{font-family:var(--serif);font-size:clamp(15px,1.2vw,17px);font-weight:400;line-height:1.85;color:var(--g600);letter-spacing:.05em;margin:0;max-width:520px;text-align:justify;text-justify:inter-ideograph}
    .about-v7-manifesto p strong{font-weight:700;color:var(--ink);font-family:var(--serif);letter-spacing:0}
    .about-v7-approach{padding:32px 0 0;border-top:1px solid rgba(10,22,40,.12)}
    .approach-title{font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:5px;text-transform:uppercase;color:var(--g400);margin-bottom:24px;display:flex;align-items:center;gap:14px;font-variant-numeric:tabular-nums}
    .approach-title::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,rgba(91,79,196,.3) 0%,transparent 100%)}
    .approach-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:18px}
    .approach-list li{display:grid;grid-template-columns:48px 1fr;grid-template-rows:auto auto;gap:6px 18px;padding-bottom:18px;border-bottom:1px dashed rgba(10,22,40,.12);align-items:baseline}
    .approach-list li:last-child{border-bottom:none;padding-bottom:0}
    .approach-icon{grid-row:1/3;grid-column:1;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border:1px solid var(--purple);position:relative;background:#fff;align-self:start;margin-top:2px}
    .approach-icon svg{width:18px;height:18px}
    .approach-num{font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:1.5px;color:var(--purple);opacity:.6;font-variant-numeric:tabular-nums;grid-row:2;grid-column:1;justify-self:center;margin-top:-2px}
    .approach-name{font-family:var(--serif);font-size:17px;font-weight:700;color:var(--ink);letter-spacing:.02em;line-height:1.3;grid-row:1;grid-column:2}
    .approach-text{font-family:var(--sans);font-size:12px;font-weight:400;color:var(--g500);letter-spacing:.05em;line-height:1.55;grid-row:2;grid-column:2}
    .about-v7-meta-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px 48px;padding-top:32px;border-top:1px solid rgba(10,22,40,.1)}
    .about-v7-meta-item{display:flex;flex-direction:column;gap:8px}
    .meta-label{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--g400);margin:0}
    .meta-value{font-family:var(--display);font-size:16px;font-weight:500;color:var(--ink);letter-spacing:.02em;margin:0;font-variant-numeric:tabular-nums;line-height:1.2}
    .about-v7-illustration{position:absolute;top:340px;right:6%;z-index:0;opacity:1;pointer-events:none;width:280px;height:280px}
    .about-v7-illustration .illu-center{position:absolute;left:50%;top:50%;width:80px;height:80px;border:1.5px solid var(--purple);border-radius:50%;transform:translate(-50%,-50%);background:radial-gradient(circle,#fff 30%,transparent 70%)}
    .about-v7-illustration .illu-center::after{content:'';position:absolute;left:50%;top:50%;width:24px;height:24px;background:var(--gold);border-radius:50%;transform:translate(-50%,-50%)}
    .about-v7-illustration .illu-ring{position:absolute;left:50%;top:50%;width:200px;height:200px;border:1px dashed rgba(91,79,196,.4);border-radius:50%;transform:translate(-50%,-50%)}
    .about-v7-illustration .illu-outer{position:absolute;left:50%;top:50%;width:280px;height:280px;border:1px solid rgba(201,160,74,.2);border-radius:50%;transform:translate(-50%,-50%)}
    .about-v7-illustration .illu-node{position:absolute;left:50%;top:50%;width:14px;height:14px;background:var(--purple);border-radius:50%;transform-origin:center;margin-left:-7px;margin-top:-7px}
    .about-v7-illustration .illu-node.gold{background:var(--gold)}
    .about-v7-illustration .illu-node.square{background:transparent;border:1.5px solid var(--purple);width:12px;height:12px;border-radius:0;margin-left:-6px;margin-top:-6px}
    .about-v7-illustration .illu-node.triangle{background:transparent;width:0;height:0;border-left:7px solid transparent;border-right:7px solid transparent;border-bottom:12px solid var(--gold);margin-left:-7px;margin-top:-12px;border-radius:0}
    .about-v7-illustration .illu-line{position:absolute;left:50%;top:50%;width:100px;height:1px;background:linear-gradient(90deg,var(--purple) 0%,transparent 100%);transform-origin:0 0}
    .about-v7-illustration .illu-line.alt{background:linear-gradient(90deg,var(--gold) 0%,transparent 100%)}
    .about-v7-geom{position:absolute;top:60px;right:5%;z-index:0;opacity:.18;pointer-events:none}
    .geom-circle{width:120px;height:120px;border:1px solid var(--purple);border-radius:50%;position:relative}
    .geom-cross{position:absolute;left:50%;top:50%;width:70px;height:1px;background:var(--gold);transform:translate(-50%,-50%)}
    .geom-cross::after{content:'';position:absolute;left:50%;top:-35px;width:1px;height:70px;background:var(--gold);transform:translateX(-50%)}
    @media(max-width:1024px){.about-v7{padding:64px 0 80px;min-height:auto;display:block}.about-v7-header{padding:0 32px;margin-bottom:64px}.about-v7-body{grid-template-columns:1fr;gap:64px;padding:0 32px}.about-v7-title .line-1{font-size:clamp(48px,10vw,96px)}.about-v7-title .line-2{font-size:clamp(40px,8vw,80px)}.about-v7-illustration{width:220px;height:220px;top:auto;bottom:40px;right:50%;transform:translateX(50%);position:relative;margin:32px auto 0}.about-v7-illustration .illu-outer{width:220px;height:220px}.about-v7-illustration .illu-ring{width:160px;height:160px}}
    @media(max-width:640px){.about-v7{padding:48px 0 64px;min-height:auto;display:block}.about-v7-header{padding:0 20px;margin-bottom:48px;gap:16px}.about-v7-num{font-size:12px}.about-v7-label{font-size:10px;letter-spacing:3px}.about-v7-body{grid-template-columns:1fr;gap:48px;padding:0 20px}.about-v7-kicker{font-size:11px;letter-spacing:4px;margin-bottom:24px}.about-v7-kicker-cn{font-size:16px;letter-spacing:6px}.about-v7-kicker::before{width:32px}.about-v7-title .line-1{font-size:44px}.about-v7-title .line-2{font-size:32px;margin-top:4px}.about-v7-manifesto{padding-left:18px}.about-v7-manifesto p{font-size:15px;line-height:1.85}.about-v7-approach{gap:16px}.approach-list li{grid-template-columns:42px 1fr;gap:4px 14px;padding-bottom:14px}.approach-name{font-size:18px}.approach-text{font-size:12px}.about-v7-meta-grid{grid-template-columns:1fr;gap:20px}.about-v7-illustration{width:180px;height:180px}.about-v7-illustration .illu-outer{width:180px;height:180px}.about-v7-illustration .illu-ring{width:130px;height:130px}.about-v7-illustration .illu-center{width:60px;height:60px}.about-v7-illustration .illu-center::after{width:18px;height:18px}}

    .sec{padding:80px 0;min-height:100vh}
    .sec-in{max-width:1440px;margin:0 auto;padding:0 48px}
    .sec-label{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:4px;text-transform:uppercase;color:var(--blue);margin-bottom:20px}
    .sec-title{font-family:var(--serif-en);font-size:clamp(26px,3.6vw,44px);font-weight:700;line-height:1.18;letter-spacing:-0.5px}
    .sec-title em{font-family:var(--display-jp);font-style:normal;color:var(--blue);font-weight:600;font-size:.85em;letter-spacing:.3px}
    .rule{width:48px;height:3px;background:linear-gradient(90deg,var(--blue) 0%,var(--gold) 100%);margin:28px 0;border-radius:0}
    @media(max-width:1024px){.sec{padding:64px 0;min-height:auto}.sec-in{padding:0 32px}}
    @media(max-width:640px){.sec{padding:48px 0;min-height:auto}.sec-in{padding:0 20px}}

    /* ── IMAGE DIVIDER ── */
    .img-divider{position:relative;height:420px;overflow:hidden}
    .img-divider img{width:100%;height:100%;object-fit:cover;filter:saturate(1.1) contrast(1.05) brightness(.98)}
    .img-divider .caption{position:absolute;bottom:0;left:0;right:0;padding:24px 48px;background:linear-gradient(transparent,rgba(0,0,0,.55));z-index:1}
    .img-divider .caption span{font-size:9px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.5);font-family:var(--mono)}
    @media(max-width:1024px){.img-divider{height:360px}}
    @media(max-width:640px){.img-divider{height:200px}.img-divider .caption{padding:12px 20px}.img-divider .caption span{font-size:8px}}

    /* ── SERVICES (table-style) ── */
    .services{background:var(--off)}
    .services .sec-label{font-size:17px;letter-spacing:5px;font-weight:600;margin-bottom:24px}
    .services .sec-title{font-size:clamp(30px,4vw,52px);letter-spacing:-0.8px}
    #why .sec-label{font-size:17px;letter-spacing:3.5px;font-weight:600;margin-bottom:16px}
    #why .sec-title{font-size:32px;letter-spacing:-0.5px;font-weight:700}
    .svc-header{display:block;margin-bottom:0;padding-bottom:56px}
    .svc-header-right{font-size:15px;color:var(--g500);line-height:1.8;padding-top:28px;max-width:720px;font-weight:400;letter-spacing:.2px}

    .svc-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:2px solid var(--ink);border-bottom:1px solid var(--g200)}
    .svc-card{padding:64px 44px 56px;display:flex;flex-direction:column;border-right:1px solid var(--g200);position:relative;transition:background .35s;background:transparent}
    .svc-card:last-child{border-right:none}
    .svc-card:hover{background:#fff}
    .svc-card-phase{font-family:var(--mono);font-size:12px;font-weight:600;letter-spacing:3.5px;text-transform:uppercase;color:var(--blue);margin-bottom:22px}
    .svc-card-num{font-family:var(--serif);font-size:48px;font-weight:700;color:var(--ink);line-height:1;letter-spacing:-1px;margin-bottom:20px}
    .svc-card-name{font-family:var(--serif);font-size:24px;font-weight:700;color:var(--ink);line-height:1.3;margin-bottom:18px;letter-spacing:0}
    .svc-card-desc{font-size:16px;color:var(--g500);line-height:1.75;font-weight:400;margin-bottom:32px;flex:1;letter-spacing:.1px}
    .svc-card-fee{padding-top:24px;border-top:1px solid var(--g200);font-family:var(--mono);font-size:12px;color:var(--g600);line-height:1.85;letter-spacing:.3px}
    .svc-card-fee-label{font-family:var(--sans);color:var(--g400);font-size:11px;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:12px;font-weight:600;display:block}
    .svc-card-fee strong{color:var(--ink);font-weight:600;font-size:14px;display:inline-block;font-family:var(--serif);letter-spacing:.3px}
    .svc-card-fee em{color:var(--blue);font-style:normal;font-weight:600}
    .svc-card-cta{margin-top:28px;font-family:var(--mono);font-size:12px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--blue);display:inline-flex;align-items:center;gap:8px;transition:gap .3s,color .3s}
    .svc-card-cta:hover{gap:14px;color:var(--orange)}
    .svc-card-cta span{font-size:14px;transition:transform .3s}
    .svc-card-cta:hover span{transform:translateX(2px)}

    @media(max-width:1024px){.svc-header{grid-template-columns:1fr;gap:24px;align-items:start;margin-bottom:0;padding-bottom:24px}.svc-header-right{justify-self:start;text-align:left;max-width:100%}.svc-grid{grid-template-columns:1fr}.svc-card{border-right:none;border-bottom:1px solid var(--g200);padding:48px 32px}.svc-card:last-child{border-bottom:none}}
    @media(max-width:640px){.svc-card{padding:36px 22px}.svc-card-num{font-size:40px;letter-spacing:-0.5px}.svc-card-name{font-size:20px}.svc-card-desc{font-size:14px;line-height:1.7}}

    /* ── ABOUT (with company card on image) ── */
    .about-layout{display:grid;grid-template-columns:1fr 1fr;gap:0;min-height:640px}
    .about-text-col{padding:80px 64px;display:flex;flex-direction:column;justify-content:center}
    .about-lead{font-size:17px;line-height:1.85;color:var(--g600);font-family:var(--serif);font-weight:400;margin-bottom:28px;letter-spacing:.1px}
    .about-lead em{font-weight:700;color:var(--blue);font-style:normal}
    .about-pull{font-family:var(--display);font-size:22px;font-weight:400;font-style:italic;line-height:1.5;color:var(--g700);margin:36px 0;padding:28px 0;border-top:1px solid var(--g200);border-bottom:1px solid var(--g200);max-width:500px}
    .about-body{font-size:16px;line-height:1.85;color:var(--g500);margin-bottom:16px;font-weight:400}
    .about-body strong{color:var(--ink);font-weight:600}
    .about-img-col{position:relative;overflow:hidden}
    .about-img-col img{width:100%;height:100%;object-fit:cover;filter:saturate(1.15) contrast(1.05) brightness(1.0)}
    .about-img-overlay{position:absolute;bottom:0;left:0;right:0;padding:40px;z-index:1}
    .about-card{background:rgba(255,255,255,.96);backdrop-filter:blur(8px);border:1px solid var(--gold);max-width:340px;box-shadow:0 12px 40px -16px rgba(10,22,40,.3)}
    .about-card-top{padding:20px 24px 16px;display:flex;align-items:center;gap:14px;border-bottom:1px solid var(--g200)}
    .about-card-top img{height:48px}
    .about-card-name{font-family:var(--serif);font-weight:700;font-size:14px}
    .about-card-name-en{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--g400);margin-top:3px;font-family:var(--sans)}
    .about-card-row{display:flex;justify-content:space-between;align-items:center;padding:12px 24px;font-size:12px;border-bottom:1px solid rgba(0,0,0,.04)}
    .about-card-row:last-child{border-bottom:none}
    .about-card-row .l{color:var(--g400);font-size:10px;letter-spacing:.5px;text-transform:uppercase;font-family:var(--mono)}
    .about-card-row .v{font-weight:600;font-family:var(--sans)}
    @media(max-width:1024px){.about-layout{grid-template-columns:1fr}.about-img-col{height:480px;order:-1}.about-text-col{padding:64px 0}}
    @media(max-width:640px){.about-img-col{height:320px}.about-text-col{padding:40px 0}.about-pull{font-size:20px;line-height:1.45;padding:20px 0;margin:24px 0}}
    @media(max-width:480px){.about-lead{font-size:18px;line-height:1.8}}

    /* ── METHOD (sticky + feat list) ── */
    .hub{background:var(--off);position:relative;overflow:hidden}
    .hub-layout{display:grid;grid-template-columns:5fr 7fr;gap:80px;align-items:start}
    .hub-sticky{position:sticky;top:120px}
    .hub-sticky::before{content:'';display:block;width:60px;height:3px;background:linear-gradient(90deg,var(--blue) 0%,var(--gold) 100%);margin-bottom:32px}
    .hub-tag{display:inline-block;padding:6px 16px;border:1px solid var(--ink);font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:24px;font-family:var(--mono)}
    .hub-name{font-family:var(--serif);font-size:clamp(30px,4.6vw,56px);font-weight:900;line-height:1.08;letter-spacing:-1.5px;margin-bottom:8px}
    .hub-name-en{font-size:13px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--g400);margin-bottom:32px;font-family:var(--sans)}
    .hub-desc{font-size:18px;line-height:1.95;color:var(--g600);margin-bottom:16px;font-weight:400}
    .hub-desc-en{font-size:18px;line-height:1.85;color:var(--g400);font-style:italic;margin-bottom:40px;font-family:var(--display);font-weight:400}
    .hub-img{width:100%;height:280px;overflow:hidden;margin-top:32px}
    .hub-img img{width:100%;height:100%;object-fit:cover;filter:saturate(1.2) contrast(1.05) brightness(1.0)}
    .feat-list{display:flex;flex-direction:column}
    .feat{padding:32px 0;border-bottom:1px solid var(--g200);display:grid;grid-template-columns:48px 1fr;gap:24px;align-items:start}
    .feat:first-child{border-top:1px solid var(--g200)}
    .feat-ico{width:48px;height:48px;border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;background:#fff;transition:all .3s}
    .feat-ico svg{width:20px;height:20px;color:var(--blue);stroke-width:1.5;transition:color .3s}
    .feat:hover .feat-ico{background:var(--gold);border-color:var(--gold)}
    .feat:hover .feat-ico svg{color:#fff}
    .feat h4{font-size:19px;font-weight:700;margin-bottom:2px;font-family:var(--sans)}
    .feat-en{font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--blue);margin-bottom:10px;font-family:var(--mono)}
    .feat p{font-size:18px;color:var(--g500);line-height:1.85;font-weight:400}
    @media(max-width:1024px){.hub-layout{grid-template-columns:1fr;gap:48px}.hub-sticky{position:static}}
    @media(max-width:640px){.hub-sticky>div:last-child{display:none}.feat{padding:20px 0;gap:14px}.feat-ico{width:40px;height:40px}.feat-ico svg{width:18px;height:18px}.feat h4{font-size:16px}.feat p{font-size:14px;line-height:1.8}}

    /* ── WHY MALAYSIA (img left, list right) ── */
    .why-layout{display:grid;grid-template-columns:1fr 1fr;gap:0;margin-top:64px;min-height:calc(100vh - 280px)}
    .why-img-col{position:relative;overflow:hidden}
    .why-img-col img{width:100%;height:100%;object-fit:cover;filter:saturate(1.2) contrast(1.05) brightness(1.0)}
    .why-content-col{padding:0 0 0 80px;display:flex;flex-direction:column;justify-content:center}
    .why-item{padding:36px 0;border-bottom:1px solid var(--g200)}
    .why-item:first-child{border-top:2px solid var(--ink)}
    .why-num{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:2px;color:var(--blue);margin-bottom:14px}
    .why-item h3{font-family:var(--serif);font-size:24px;font-weight:700;margin-bottom:4px;line-height:1.3}
    .why-item h3-en{font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--blue);margin-bottom:14px;font-family:var(--mono)}
    .why-item p{font-size:18px;color:var(--g500);line-height:1.9;font-weight:400}
    @media(max-width:1024px){.why-layout{grid-template-columns:1fr;min-height:auto}.why-img-col{height:420px;order:-1}.why-content-col{padding:48px 0 0}}
    @media(max-width:640px){.why-img-col{height:280px}.why-item{padding:24px 0}.why-item h3{font-size:20px}.why-item p{font-size:15px;line-height:1.8}#why .sec-label{font-size:18px;letter-spacing:4px;margin-bottom:12px}#why .sec-title{font-size:26px;letter-spacing:-.5px}}

    /* ── GLOBAL (dark section) ── */
    .global{position:relative;overflow:hidden}
    .global-bg{position:absolute;inset:0;z-index:0}
    .global-bg img{width:100%;height:100%;object-fit:cover;opacity:.10;filter:grayscale(100%) brightness(.6)}
    .global-content{position:relative;z-index:1;background:var(--blue-deep);color:var(--off);padding:80px 0;min-height:100vh;display:flex;align-items:center}
    .global .sec-label{color:rgba(201,160,74,.55);font-size:14px;letter-spacing:6px}
    .global .sec-title{color:var(--off)}
    .global .sec-title em{color:var(--gold)}
    .global .rule{background:linear-gradient(90deg,var(--blue) 0%,var(--gold) 100%);width:48px;height:3px;border-radius:0;margin:28px 0}
    .global-intro{font-size:18px;line-height:1.95;color:rgba(250,246,237,.7);max-width:600px;margin-bottom:72px;font-weight:400}
    .global-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:0;border-top:1px solid rgba(201,160,74,.2)}
    .global-item{padding:44px 28px;border-right:1px solid rgba(201,160,74,.12);position:relative;transition:background .3s}
    .global-item:last-child{border-right:none}
    .global-item:hover{background:rgba(255,255,255,.03)}
    .global-code{font-size:48px;font-weight:900;letter-spacing:3px;line-height:1;color:rgba(255,255,255,.92);margin-bottom:18px;font-family:var(--sans)}
    .global-item h3{font-family:var(--serif);font-size:20px;font-weight:700;margin-bottom:4px;line-height:1.3}
    .global-item h3-en{font-size:10px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:rgba(201,160,74,.4);margin-bottom:16px;font-family:var(--mono)}
    .global-item p{font-size:18px;color:rgba(250,246,237,.65);line-height:1.75;font-weight:400}
    .global-line{width:24px;height:2px;background:var(--gold);margin-bottom:14px;opacity:.85}
    @media(max-width:1024px){.global-grid{grid-template-columns:repeat(3,1fr)}.global-item{border-right:1px solid rgba(255,255,255,.08)}.global-item:nth-child(3n){border-right:none}}
    @media(max-width:768px){.global-grid{grid-template-columns:1fr 1fr}.global-item:nth-child(2n){border-right:none}.global-item:nth-child(3n){border-right:1px solid rgba(255,255,255,.08)}}
    @media(max-width:480px){.global-grid{grid-template-columns:1fr;gap:0}.global-item{border-right:none!important;border-bottom:1px solid rgba(255,255,255,.06);padding:32px 20px}.global-item:last-child{border-bottom:none}.global-code{font-size:36px}.global-item h3{font-size:18px}.global-item p{font-size:15px;line-height:1.7}}

    /* ── VISION (two columns with images) ── */
    .vision-layout{display:grid;grid-template-columns:1fr 1fr;gap:0;min-height:calc(100vh - 280px);position:relative}
    .vision-col{padding:80px 64px;display:flex;flex-direction:column;justify-content:center;position:relative}
    .vision-col:first-child::after{content:'';position:absolute;top:8%;bottom:8%;right:-1px;width:2px;background:linear-gradient(180deg,transparent 0%,var(--blue) 25%,var(--gold) 75%,transparent 100%)}
    .vision-col .sec-label{margin-bottom:24px}
    .vision-col h3{font-family:var(--serif-en);font-size:clamp(22px,2.8vw,32px);font-weight:900;line-height:1.35;margin-bottom:20px;letter-spacing:-.5px}
    .vision-col h3 em{font-family:var(--display-jp);font-style:normal;color:var(--blue);font-weight:600;font-size:.95em;letter-spacing:.3px}
    .vision-col p{font-size:18px;color:var(--g500);line-height:1.95;font-weight:400}
    .vision-col .vision-img{margin-top:32px;height:200px;overflow:hidden;position:relative}
    .vision-col .vision-img::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(30,58,95,.18) 100%);pointer-events:none}
    .vision-col .vision-img img{width:100%;height:100%;object-fit:cover;filter:saturate(1.1) contrast(1.05) brightness(1.0)}
    @media(max-width:1024px){.vision-layout{grid-template-columns:1fr;min-height:auto}.vision-col{padding:64px 0}.vision-col:first-child::after{display:none}.vision-col:first-child{border-bottom:1px solid var(--g200)}}
    @media(max-width:640px){.vision-col{padding:40px 0}.vision-col h3{font-size:22px;line-height:1.4}.vision-col p{font-size:15px;line-height:1.85}.vision-col .vision-img{height:140px;margin-top:24px}.services .sec-title{font-size:36px;letter-spacing:-1px}.svc-header-right{font-size:15px;padding-top:24px;line-height:1.85}}

    /* ── FAQ ── */
    .faq{background:var(--off)}
    .faq-list{display:flex;flex-direction:column;border-top:2px solid var(--ink)}
    .faq-item{display:grid;grid-template-columns:64px 1fr 1fr;gap:32px;padding:32px 0;border-bottom:1px solid var(--g200);align-items:start}
    .faq-num{font-family:var(--mono);font-size:12px;font-weight:500;letter-spacing:2px;color:var(--blue);padding-top:6px}
    .faq-q{font-family:var(--serif);font-size:19px;font-weight:600;line-height:1.4}
    .faq-q-en{display:block;font-family:var(--display);font-style:italic;font-size:14px;color:var(--g500);font-weight:400;margin-top:6px}
    .faq-a{font-size:18px;color:var(--g500);line-height:1.95;font-weight:400}
    @media(max-width:1024px){.faq-item{grid-template-columns:48px 1fr 1fr;gap:24px}}
    @media(max-width:768px){.faq-item{grid-template-columns:40px 1fr;gap:16px;padding:24px 0}.faq-a{grid-column:2/3}.faq-q{font-size:16px}}
    @media(max-width:480px){.faq-item{grid-template-columns:32px 1fr;gap:12px;padding:24px 0}.faq-q{font-size:15px}.faq-a{font-size:14px;line-height:1.85}}

    /* ── CONTACT (form) ── */
    .contact-layout{display:grid;grid-template-columns:1fr 1fr;gap:96px;margin-top:64px}
    .contact-info{padding:0}
    .contact-info dt{font-family:var(--mono);font-size:10px;color:var(--blue);letter-spacing:3px;text-transform:uppercase;margin-top:36px;padding-bottom:10px;border-bottom:1px solid var(--g200)}
    .contact-info dt:first-child{margin-top:0}
    .contact-info dd{font-family:var(--serif);font-size:20px;color:var(--ink);line-height:1.5;margin-top:12px;font-weight:600}
    .contact-info dd small{display:block;font-family:var(--sans);font-size:13px;color:var(--g500);font-weight:400;margin-top:4px}
    .form-group{margin-bottom:32px}
    .form-group label{display:block;font-family:var(--mono);font-size:10px;color:var(--blue);letter-spacing:3px;text-transform:uppercase;margin-bottom:10px}
    .form-group input,.form-group textarea,.form-group select{width:100%;border:0;border-bottom:1px solid var(--g300);background:transparent;padding:12px 0;font-family:var(--sans);font-size:18px;color:var(--ink);font-weight:400;transition:border-color .3s;border-radius:0;-webkit-appearance:none;appearance:none}
    .form-group input:focus,.form-group textarea:focus,.form-group select:focus{outline:none;border-bottom-color:var(--blue)}
    .form-group textarea{resize:vertical;min-height:100px}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:24px}
    .form-submit{background:var(--ink);color:#fff;border:0;padding:18px 40px;font-family:var(--mono);font-size:11px;letter-spacing:3px;text-transform:uppercase;cursor:pointer;margin-top:8px;transition:background .3s}
    .form-submit:hover{background:var(--blue)}
    @media(max-width:1024px){.contact-layout{grid-template-columns:1fr;gap:64px}}
    @media(max-width:768px){.contact-layout{gap:48px}.form-row{grid-template-columns:1fr;gap:0}}
    @media(max-width:480px){.contact-info dd{font-size:17px}.form-group{margin-bottom:20px}.form-group input,.form-group textarea,.form-group select{font-size:16px}.form-submit{width:100%;padding:16px 32px}}

    /* ── CTA ── */
    .cta{background:var(--off);color:var(--ink);padding:80px 0;text-align:center;position:relative;overflow:hidden;border-top:1px solid var(--rule-light);border-bottom:1px solid var(--rule-light);min-height:100vh;display:flex;align-items:center}
    .cta::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:140px;height:3px;background:linear-gradient(90deg,var(--blue),var(--gold),var(--blue));z-index:1}
    .cta::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:240px;height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent);opacity:.6;z-index:1}
    .cta h2{font-family:var(--serif-en);font-size:clamp(32px,5.2vw,68px);font-weight:900;line-height:1.12;letter-spacing:-1.5px;margin-bottom:20px;max-width:900px;margin-left:auto;margin-right:auto}
    .cta h2 em{font-family:var(--display-jp);font-style:normal;font-weight:600;font-size:.85em;letter-spacing:.3px;background:linear-gradient(135deg,var(--gold) 0%,var(--orange) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .cta p{font-size:18px;color:var(--g500);margin-bottom:48px;max-width:520px;margin-left:auto;margin-right:auto;line-height:1.85;font-weight:400}
    .cta .btn-fill{background:linear-gradient(135deg,var(--blue) 0%,var(--gold) 100%);color:#fff;position:relative;z-index:1}
    .cta .btn-fill:hover{background:linear-gradient(135deg,#2d5588 0%,#d4a850 100%)}
    .cta .btn-ghost{background:transparent;color:var(--ink);border:1px solid var(--g300);margin-left:12px}@media(max-width:640px){.cta .btn-ghost{margin-left:0;margin-top:12px;display:block}.cta .btn-fill{display:block;margin:0 auto}}
    .cta .btn-ghost:hover{border-color:var(--blue);color:var(--blue);background:rgba(30,58,95,.04)}

    /* ── FOOTER ── */
    .footer{background:var(--paper);color:var(--g500);padding:80px 0 0;position:relative}
    .footer::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--blue) 0%,var(--gold) 50%,var(--blue) 100%)}
    .footer-in{max-width:1440px;margin:0 auto;padding:0 48px}
    .footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:56px}
    .footer-logo{height:75px;margin-bottom:14px}
    .footer-brand{font-family:var(--serif);font-size:18px;font-weight:700;color:var(--ink);margin-bottom:2px;letter-spacing:-.2px}
    .footer-brand-en{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--blue);margin-bottom:14px;font-family:var(--mono);opacity:.7}
    .footer-top>p{font-size:18px;line-height:1.75;color:var(--g500);max-width:280px}
    .footer-top h4{font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--blue);margin-bottom:18px;font-family:var(--mono);position:relative;padding-bottom:10px}
    .footer-top h4::after{content:'';position:absolute;bottom:0;left:0;width:24px;height:2px;background:linear-gradient(90deg,var(--blue),var(--gold))}
    .footer-links{display:flex;flex-direction:column;gap:10px}
    .footer-links a{font-size:18px;color:var(--g500);transition:color .2s;font-weight:400}
    .footer-links a:hover{color:var(--blue)}
    .footer-bottom{padding:28px 0;border-top:1px solid var(--rule-light);display:flex;justify-content:space-between;align-items:center;font-size:12px;letter-spacing:.3px;color:var(--g400);font-family:var(--mono)}
    @media(max-width:1024px){.footer-top{grid-template-columns:2fr 1fr 1fr 1fr;gap:32px}}
    @media(max-width:768px){.footer-top{grid-template-columns:1fr 1fr;gap:40px}.footer-bottom{flex-direction:column;gap:12px;text-align:center}}
    @media(max-width:480px){.footer-top{grid-template-columns:1fr;gap:32px}.footer-in{padding:0 20px}.footer-logo{height:60px}}
  </style>
</head>
<body>

